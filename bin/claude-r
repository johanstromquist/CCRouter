#!/usr/bin/env bash
# claude-r: Resume the last Claude Code session for the current workspace.
# Reads session info persisted by the CCRouter Cursor extension.
# Skips sessions that are already active (running in another terminal).
#
# Supports two persistence formats:
#   New: directory of per-bridge files at last-sessions/{hash}/{port}.json
#   Old: single JSON array file at last-sessions/{hash}.json
#
# Usage:
#   claude-r           # resume the next available session
#   claude-r --list    # show all saved sessions for this workspace
#   claude-r --pick    # interactive picker for multi-session workspaces

set -euo pipefail

SESSIONS_DIR="${HOME}/.ccrouter/last-sessions"
DAEMON_URL="http://127.0.0.1:19919"
CONFIG_FILE="$HOME/.ccrouter/config.json"
if [ -f "$CONFIG_FILE" ]; then
  CONFIGURED_URL=$(python3 -c "import json,sys; print(json.load(open(sys.argv[1])).get('daemonUrl',''))" "$CONFIG_FILE" 2>/dev/null || echo "")
  if [ -n "$CONFIGURED_URL" ]; then
    DAEMON_URL="$CONFIGURED_URL"
  fi
fi

# Pre-claim: register session as active in daemon BEFORE launching claude.
# This prevents other claude-r instances from picking the same session.
preclaim_session() {
  local sid="$1"
  local cwd="$PWD"
  curl -s -X POST "$DAEMON_URL/register" \
    -H "Content-Type: application/json" \
    -d "{\"session_id\":\"$sid\",\"cwd\":\"$cwd\",\"pid\":$$}" \
    --connect-timeout 1 --max-time 2 > /dev/null 2>&1 || true
}

# Hash the cwd to find the session file/directory
CWD_HASH=$(echo -n "$PWD" | md5 2>/dev/null || echo -n "$PWD" | md5sum 2>/dev/null | cut -d' ' -f1)
SESSION_PATH="${SESSIONS_DIR}/${CWD_HASH}"

# Load sessions from both directory and file formats, merge and deduplicate
load_sessions() {
  python3 -c "
import json, os, sys

entries = []
seen = set()

def add_entry(e):
    sid = e.get('sessionId')
    if sid and sid not in seen:
        entries.append(e)
        seen.add(sid)

# Read per-bridge directory (new format)
d = sys.argv[1]
if os.path.isdir(d):
    for f in os.listdir(d):
        if not f.endswith('.json'): continue
        try:
            data = json.load(open(os.path.join(d, f)))
            if isinstance(data, dict): add_entry(data)
            elif isinstance(data, list):
                for e in data: add_entry(e)
        except: pass

# Also read single file (old format) -- may have sessions not in the directory
f = d + '.json'
if os.path.isfile(f):
    try:
        data = json.load(open(f))
        if isinstance(data, list):
            for e in data: add_entry(e)
    except: pass

entries.sort(key=lambda e: e.get('updatedAt',''), reverse=True)
print(json.dumps(entries))
" "${SESSION_PATH}"
}

SESSIONS=$(load_sessions)
COUNT=$(echo "$SESSIONS" | python3 -c "import sys,json; print(len(json.load(sys.stdin)))" 2>/dev/null || echo "0")

if [ "$COUNT" = "0" ]; then
  echo "No saved sessions for this workspace ($PWD)"
  echo "Start a session normally with 'claude' first."
  exit 1
fi

# Handle flags
case "${1:-}" in
  --list)
    echo "Saved sessions for $PWD:"
    echo ""
    echo "$SESSIONS" | python3 -c "
import sys, json, urllib.request

sessions = json.load(sys.stdin)
for i, s in enumerate(sessions):
    name = s.get('friendlyName', 'unknown')
    sid = s.get('sessionId', '?')
    updated = s.get('updatedAt', '?')
    # Check if active
    active = ''
    try:
        resp = urllib.request.urlopen('$DAEMON_URL/session/' + sid, timeout=1)
        data = json.loads(resp.read())
        if data.get('is_active') == 1:
            active = ' [ACTIVE]'
    except: pass
    print(f'  [{i+1}] {name}{active} (session: {sid[:12]}..., last seen: {updated})')
"
    exit 0
    ;;
  --pick)
    echo "Saved sessions for $PWD:"
    echo ""
    echo "$SESSIONS" | python3 -c "
import sys, json, urllib.request

sessions = json.load(sys.stdin)
for i, s in enumerate(sessions):
    name = s.get('friendlyName', 'unknown')
    sid = s.get('sessionId', '?')
    active = ''
    try:
        resp = urllib.request.urlopen('$DAEMON_URL/session/' + sid, timeout=1)
        data = json.loads(resp.read())
        if data.get('is_active') == 1:
            active = ' [ACTIVE]'
    except: pass
    print(f'  [{i+1}] {name}{active} ({sid[:12]}...)')
"
    echo ""
    read -p "Pick a session number: " PICK
    SESSION_ID=$(echo "$SESSIONS" | python3 -c "
import sys, json
sessions = json.load(sys.stdin)
idx = int('$PICK') - 1
if 0 <= idx < len(sessions):
    print(sessions[idx]['sessionId'])
else:
    print('')
" 2>/dev/null)
    if [ -z "$SESSION_ID" ]; then
      echo "Invalid selection."
      exit 1
    fi
    echo "Resuming session $SESSION_ID..."
    preclaim_session "$SESSION_ID"
    exec claude --resume "$SESSION_ID"
    ;;
  "")
    # Default: resume the first session that isn't already active
    RESULT=$(echo "$SESSIONS" | python3 -c "
import sys, json, urllib.request

sessions = json.load(sys.stdin)
for s in sessions:
    sid = s.get('sessionId', '')
    name = s.get('friendlyName', 'unknown')
    if not sid:
        continue
    # Check if this session is already active
    try:
        resp = urllib.request.urlopen('$DAEMON_URL/session/' + sid, timeout=1)
        data = json.loads(resp.read())
        if data.get('is_active') == 1:
            continue  # skip, already running
    except:
        pass  # daemon unreachable or session not found -- safe to resume
    # This session is available
    print(json.dumps({'sessionId': sid, 'friendlyName': name}))
    sys.exit(0)

# All sessions are active -- nothing to resume
print('')
" 2>/dev/null)

    if [ -z "$RESULT" ]; then
      echo "All saved sessions for this workspace are already active."
      echo "Start a new session with 'claude' instead."
      exit 0
    fi

    SESSION_ID=$(echo "$RESULT" | python3 -c "import sys,json; print(json.load(sys.stdin)['sessionId'])")
    FRIENDLY_NAME=$(echo "$RESULT" | python3 -c "import sys,json; print(json.load(sys.stdin)['friendlyName'])")

    if [ "$COUNT" != "1" ]; then
      echo "Resuming next available session: $FRIENDLY_NAME (skipping active ones)"
      echo "(Use 'claude-r --pick' to choose a specific one)"
      echo ""
    fi

    echo "Resuming session: $FRIENDLY_NAME ($SESSION_ID)"
    preclaim_session "$SESSION_ID"
    exec claude --resume "$SESSION_ID"
    ;;
  *)
    echo "Usage: claude-r [--list | --pick]"
    exit 1
    ;;
esac
