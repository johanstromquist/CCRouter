{
  "name": "@johnmion/ccrouter",
  "version": "1.0.8",
  "description": "Cross-session communication for Claude Code - lets multiple sessions discover each other, exchange messages, and read transcripts",
  "type": "module",
  "main": "dist/mcp-server.js",
  "bin": {
    "ccrouter": "dist/cli.js"
  },
  "files": [
    "dist/",
    "data/",
    "hooks/",
    "cursor-extension/*.vsix",
    "cursor-extension/extension.js",
    "cursor-extension/package.json"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "build:vsix": "cd cursor-extension && npx -y @vscode/vsce package --allow-missing-repository",
    "prepublishOnly": "npm run build:vsix && npm run build",
    "start:daemon": "node dist/daemon.js",
    "start:mcp": "node dist/mcp-server.js"
  },
  "keywords": [
    "claude-code",
    "mcp",
    "multi-agent",
    "session-router"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/johanstromquist/CCRouter.git"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "better-sqlite3": "^11.8.2",
    "ws": "^8.19.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.13.5",
    "typescript": "^5.7.3"
  }
}
